# Environment variables for local development
PORT=8080
NODE_ENV=development

# Google Cloud Storage bucket name (used by the GCS SDK for authenticated downloads)
GCS_BUCKET_NAME=livingdocs-image-live

# Google Cloud Storage bucket base URL (without trailing slash)
GCS_BUCKET_BASE_URL=https://storage.cloud.google.com/livingdocs-image-live

# ---------------------------------------------------------------------------
# Performance tuning
# ---------------------------------------------------------------------------

# libvips thread pool size for Sharp.
# Should match Cloud Run --concurrency so each parallel request gets its own
# thread. Set to 1 on memory-constrained instances to avoid AVIF timeout 503s.
# Default: 1
SHARP_CONCURRENCY=1

# AVIF encoder speed (libaom): 0 = best compression / slowest, 9 = fastest / largest files.
# Speed 6 cuts encode time to ~1–2 s on a 2000 px image with ~5% larger files vs speed 4.
# Increase to 8–9 for dev/QA where file size is less critical than latency.
# Default: 6
AVIF_SPEED=6

# Maximum size of the processed-image LRU cache (output buffers, keyed by path+params).
# Default: 512
IMAGE_CACHE_MAX_MB=512

# Maximum size of the GCS source-image LRU cache (raw download buffers, keyed by path only).
# Avoids repeated GCS fetches when the same image is requested at different output params.
# Default: 128
GCS_SOURCE_CACHE_MAX_MB=128

# ---------------------------------------------------------------------------
# Face detection
# ---------------------------------------------------------------------------

# Maximum number of concurrent TF.js inference dispatches to the Worker thread.
# The Worker serializes execution anyway; higher values just queue more work.
# Default: 1
FACE_DETECTION_CONCURRENCY=1

# Hard timeout (ms) for the full face detection pipeline per request.
# Must stay well below Cloud Run timeoutSeconds (30 s default).
# Default: 8000
FACE_DETECTION_TIMEOUT_MS=8000

# Maximum image width (px) fed to TF.js models.
# Larger images are scaled down before inference and coordinates scaled back up.
# Lower values = faster inference; 640 px is sufficient for reliable face detection.
# Default: 640
FACE_DETECTION_MAX_INPUT_WIDTH=640

# ---------------------------------------------------------------------------
# Google Cloud (for deployment)
# ---------------------------------------------------------------------------
# GCP_PROJECT_ID=your-project-id
# GCP_REGION=europe-west3
